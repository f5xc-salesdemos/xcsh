{
  "rules": {
    "terminology": {
      "defaultTerms": true,
      "exclude": [
        "repo\\b",
        "bug[- ]fix(es)?",
        "build system(s)?",
        "readme(s)?",
        "to-?do(s)?(?=[ ,.])",
        "regexp?(s)?",
        "Bash",
        "Markdown",
        "Git",
        "API",
        "API['\u2019]?s",
        "HTML",
        "SSH",
        "JSON",
        "SVG",
        "SQLite",
        "Unicode",
        "ID",
        "id['\u2019]?s",
        "check[- ]box(es)?",
        "key[/ ]?value",
        "CLI tool(s)?",
        "Visual ?Studio ?Code",
        "V[ -]?S[ -]?Code",
        "built ?in(s)?",
        "trade ?off(s)?",
        "anti[- ]pattern(s)?",
        "auto[- ]fix",
        "auto[- ]format(ting|ted|ter)?",
        "color-?blind",
        "file-?type(s)?",
        "lock[- ]file(s)?",
        "re[- ]export(s|ing|ed)?",
        "copy[- ]past(e|ed|ing)?"
      ]
    }
  }
}
