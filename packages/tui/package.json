{
	"type": "module",
	"name": "@f5xc-salesdemos/pi-tui",
	"version": "14.6.0",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"homepage": "https://github.com/f5xc-salesdemos/xcsh",
	"author": "Can Boluk",
	"contributors": [
		"Mario Zechner"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f5xc-salesdemos/xcsh.git",
		"directory": "packages/tui"
	},
	"bugs": {
		"url": "https://github.com/f5xc-salesdemos/xcsh/issues"
	},
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --preload ./test/preload.ts test/*.test.ts",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@f5xc-salesdemos/pi-natives": "workspace:*",
		"@f5xc-salesdemos/pi-utils": "workspace:*",
		"marked": "^17.0"
	},
	"devDependencies": {
		"chalk": "^5.6",
		"@xterm/headless": "^6.0"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./components/*": {
			"types": "./src/components/*.ts",
			"import": "./src/components/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
