{
	"name": "@f5xc-salesdemos/pi-natives",
	"version": "17.3.0",
	"description": "Native Rust bindings for grep, clipboard, image processing, syntax highlighting, PTY, and shell operations via N-API",
	"homepage": "https://github.com/f5xc-salesdemos/xcsh",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f5xc-salesdemos/xcsh.git",
		"directory": "packages/natives"
	},
	"bugs": {
		"url": "https://github.com/f5xc-salesdemos/xcsh/issues"
	},
	"keywords": [
		"napi",
		"rust",
		"native",
		"grep",
		"text-processing",
		"clipboard",
		"image",
		"pty",
		"shell",
		"syntax-highlighting"
	],
	"main": "./native/index.js",
	"types": "./native/index.d.ts",
	"scripts": {
		"build": "bun scripts/build-native.ts",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun run build && bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"embed:native": "bun scripts/embed-native.ts",
		"bench": "bun bench/grep.ts"
	},
	"devDependencies": {
		"@napi-rs/cli": "3.6.0",
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"napi": {
		"binaryName": "pi_natives",
		"triples": {
			"x86_64-unknown-linux-gnu": { "platformArchABI": "linux-x64-gnu" },
			"aarch64-unknown-linux-gnu": { "platformArchABI": "linux-arm64-gnu" },
			"x86_64-apple-darwin": { "platformArchABI": "darwin-x64" },
			"aarch64-apple-darwin": { "platformArchABI": "darwin-arm64" },
			"x86_64-pc-windows-msvc": { "platformArchABI": "win32-x64-msvc" }
		}
	},
	"optionalDependencies": {
		"@f5xc-salesdemos/pi-natives-linux-x64-gnu": "17.3.0",
		"@f5xc-salesdemos/pi-natives-linux-arm64-gnu": "17.3.0",
		"@f5xc-salesdemos/pi-natives-darwin-x64": "17.3.0",
		"@f5xc-salesdemos/pi-natives-darwin-arm64": "17.3.0",
		"@f5xc-salesdemos/pi-natives-win32-x64-msvc": "17.3.0"
	},
	"files": [
		"native",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./native/index.d.ts",
			"import": "./native/index.js"
		}
	}
}
