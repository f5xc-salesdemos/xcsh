{
	"type": "module",
	"name": "@f5xc-salesdemos/pi-utils",
	"version": "15.2.0",
	"description": "Shared utilities for pi packages",
	"homepage": "https://github.com/f5xc-salesdemos/xcsh",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f5xc-salesdemos/xcsh.git",
		"directory": "packages/utils"
	},
	"bugs": {
		"url": "https://github.com/f5xc-salesdemos/xcsh/issues"
	},
	"keywords": [
		"utilities",
		"cli",
		"logging",
		"streams"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"beautiful-mermaid": "^1.1",
		"handlebars": "^4.7.9",
		"winston": "^3.19",
		"winston-daily-rotate-file": "^5.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3",
		"@f5xc-salesdemos/pi-natives": "workspace:*"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
