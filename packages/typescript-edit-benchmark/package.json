{
	"type": "module",
	"private": true,
	"name": "@f5xc-salesdemos/typescript-edit-benchmark",
	"version": "0.0.1",
	"description": "Edit benchmark suite using TypeScript source code mutations",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f5xc-salesdemos/xcsh.git",
		"directory": "packages/typescript-edit-benchmark"
	},
	"main": "./src/index.ts",
	"bin": {
		"typescript-edit-benchmark": "src/index.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"generate": "bun run src/generate.ts --typescript-dir /tmp/pi-mono-source --count-per-type 4",
		"start": "bun run src/index.ts"
	},
	"dependencies": {
		"@babel/generator": "^7.29",
		"@babel/parser": "^7.29",
		"@babel/traverse": "^7.29",
		"@babel/types": "^7.29",
		"@f5xc-salesdemos/pi-agent-core": "workspace:*",
		"@f5xc-salesdemos/xcsh": "workspace:*",
		"@f5xc-salesdemos/pi-utils": "workspace:*",
		"diff": "^8.0",
		"prettier": "^3.8",
		"regexp-tree": "^0.1",
		"@f5xc-salesdemos/pi-ai": "workspace:*",
		"@f5xc-salesdemos/pi-tui": "workspace:*"
	},
	"devDependencies": {
		"@types/babel__generator": "^7.27",
		"@types/babel__traverse": "^7.28",
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
